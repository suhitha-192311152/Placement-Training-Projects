import java.util.*;
public class PasswordManager {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        HashMap<String, String> vault = new HashMap<>();
        while (true) {
            System.out.println("\n1.Save 2.Get 3.Exit");
            int ch = sc.nextInt();
            sc.nextLine();
            if (ch == 1) {
                System.out.print("App name: ");
                String app = sc.nextLine();
                System.out.print("Password: ");
                String pass = sc.nextLine();
                vault.put(app, pass);
            } 
            else if (ch == 2) {
                System.out.print("Enter app name: ");
                String app = sc.nextLine();
                System.out.println("Password: " + vault.getOrDefault(app, "Not found"));
            } 
            else break;
        }
    }
}
